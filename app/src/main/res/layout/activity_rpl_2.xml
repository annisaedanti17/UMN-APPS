<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="220dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/ellipse_biru" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="35dp"
                    android:gravity="center"
                    android:text="Jalur RPL Magister\nManajemen Teknologi (S2)"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-120dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:elevation="5dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/banner_pendaftaran" />

                </RelativeLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="RPL Magister Manajemen Teknologi (S2)"
                    android:textAlignment="center"
                    android:textColor="@color/colorHeadingPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="120dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:background="#0077B6" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="15dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/rpl_2" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:background="#80003554"
                        android:padding="10dp"
                        android:text="Program Rekognisi Pembelajaran Lampau (S2)"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:text="&quot;Pengalaman adalah fondasi, pendidikan adalah penguatnya. Melalui RPL Magister Manajemen Teknologi, Anda memimpin perubahan dengan kredibilitas akademik.&quot;"
                    android:textAlignment="center"
                    android:textColor="@color/colorHeadingPrimary"
                    android:textSize="12sp"
                    android:textStyle="italic" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:text="Rekognisi Pembelajaran Lampau (RPL) Tipe A di Universitas Multimedia Nusantara (UMN) tahun 2025 untuk menyetarakan pengalaman kerja dan pembelajaran nonformal ke dalam kualifikasi akademik. Melalui kerangka asesmen yang transparan dan akuntabel, UMN berkomitmen memperluas akses pendidikan tinggi serta mendukung pengembangan SDM berbasis ICT dan pembelajaran sepanjang hayat."
                    android:textColor="@color/colorHeadingPrimary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Persyaratan Masuk"
                    android:textColor="@color/colorHeadingPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="30dp"
                    app:cardBackgroundColor="#003554"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Program ini berada pada jenjang Magister dengan akreditasi &quot;Unggul&quot;.\nPersyaratannya meliputi:"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="1. Isi Lengkap Formulir Pendaftaran Online\n2. Pendidikan Terakhir: Lulusan Program Strata 1 (S1) atau Sarjana yang terakreditasi oleh BAN-PT.\n3. Kesesuaian Ilmu: Lulusan S1 dari berbagai rumpun ilmu diperbolehkan mendaftar selama memenuhi kualifikasi persyaratan lainnya.\n4. Pengalaman Kerja: Wajib memiliki pengalaman kerja pada bidang yang relevan dengan Manajemen Teknologi selama minimal 5 tahun.\n5. Izin Instansi:\n    • Bagi Aparatur Sipil Negara (ASN), wajib memperoleh izin dari Pembina Kepegawaian.\n    • Bagi karyawan swasta (Non-ASN), wajib memperoleh izin dari atasan langsung.\n6. Dokumen Wajib (Khusus RPL Tipe A2): Menyiapkan Portofolio pribadi, sertifikasi keahlian, dan surat keterangan kerja yang divalidasi oleh HRD atau Atasan yang mencantumkan job description secara detail."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/back" />


</RelativeLayout>
